{"count":21,"zones":["Eastbrook Vale","Mirefen Marsh","Thornpeak Heights","The Drowned Temple"],"npcs":[{"id":"apothecary_lin","name":"Apothecary Lin","title":"Herbalist","zone":"Eastbrook Vale","pos":{"x":11,"z":-3},"greeting":"Careful where you step in the eastern woods, friend.","role":"Quest giver","quests":[{"name":"Webwood Menace","file":"quests/zones/01-eastbrook-vale/q-spiders.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/apothecary_lin.png"},{"id":"brother_aldric","name":"Brother Aldric","title":"Priest of the Vale","zone":"Eastbrook Vale","pos":{"x":-14,"z":-10},"greeting":"The Light keep you. Even the dead find no rest here of late.","role":"Quest giver","quests":[{"name":"The Restless Dead","file":"quests/zones/01-eastbrook-vale/q-bones.md"},{"name":"Whispers Below","file":"quests/zones/01-eastbrook-vale/q-whispers.md"},{"name":"The Names of the Dead","file":"quests/zones/01-eastbrook-vale/q-names-of-the-dead.md"},{"name":"Silence the Call","file":"quests/zones/01-eastbrook-vale/q-silence-the-call.md"},{"name":"The Binding Rite","file":"quests/zones/01-eastbrook-vale/q-rite.md"},{"name":"The Sexton's Bell","file":"quests/zones/01-eastbrook-vale/q-sexton.md"},{"name":"Into the Hollow","file":"quests/zones/01-eastbrook-vale/q-hollow.md"},{"name":"The Gravecaller's Trail","file":"quests/zones/01-eastbrook-vale/q-gravecallers-trail.md"},{"name":"Muster at Fenbridge","file":"quests/zones/02-mirefen-marsh/q-fenbridge-muster.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/brother_aldric.png"},{"id":"fisherman_brandt","name":"Fisherman Brandt","title":"Old Salt","zone":"Eastbrook Vale","pos":{"x":-16,"z":6},"greeting":"Grlmurlgrl— sorry, been listening to those fish-men too long.","role":"Quests & vendor","quests":[{"name":"Trouble at the Lake","file":"quests/zones/01-eastbrook-vale/q-murlocs.md"}],"market":false,"vendorItems":["Simple Fishing Pole"],"render":"npcs/_renders/fisherman_brandt.png"},{"id":"foreman_odell","name":"Foreman Odell","title":"Mine Foreman","zone":"Eastbrook Vale","pos":{"x":-4,"z":-14},"greeting":"Whole dig's crawling with those candle-headed vermin!","role":"Quest giver","quests":[{"name":"Rats in the Mine","file":"quests/zones/01-eastbrook-vale/q-mine.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/foreman_odell.png"},{"id":"marshal_redbrook","name":"Marshal Redbrook","title":"Town Marshal","zone":"Eastbrook Vale","pos":{"x":4,"z":6},"greeting":"Keep your blade close, friend. The Vale is not what it was.","role":"Quest giver","quests":[{"name":"Wolves at the Door","file":"quests/zones/01-eastbrook-vale/q-wolves.md"},{"name":"The Old Wolf","file":"quests/zones/01-eastbrook-vale/q-greyjaw.md"},{"name":"Bandits of the Vale","file":"quests/zones/01-eastbrook-vale/q-bandits.md"},{"name":"The Ringleader","file":"quests/zones/01-eastbrook-vale/q-ringleader.md"},{"name":"Mogger Must Fall","file":"quests/zones/01-eastbrook-vale/q-mogger.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/marshal_redbrook.png"},{"id":"smith_haldren","name":"Smith Haldren","title":"Armorer & Weaponsmith","zone":"Eastbrook Vale","pos":{"x":7,"z":17},"greeting":"Mind the sparks, friend. Good steel is the difference between a scar and a grave.","role":"Vendor","quests":[],"market":false,"vendorItems":["Eastbrook Arming Sword","Bronzework Mace","Vale Carving Knife","Hickory Shortstaff","Eastbrook Chainmail Vest","Valespun Robe","Tanned Leather Jerkin","Hobnailed Boots","Eastbrook Wool Trousers"],"render":"npcs/_renders/smith_haldren.png"},{"id":"the_merchant","name":"The Merchant","title":"Keeper of the World Market","zone":"Eastbrook Vale","pos":{"x":0,"z":10},"greeting":"Welcome to the World Market, friend. Buy from every adventurer in the realm — or set out your own wares and let coin find you.","role":"Vendor","quests":[],"market":true,"vendorItems":[],"render":"npcs/_renders/the_merchant.png"},{"id":"trader_wilkes","name":"Trader Wilkes","title":"Provisioner","zone":"Eastbrook Vale","pos":{"x":-7,"z":3},"greeting":"Fresh bread, clean water, fair prices. What can I get you?","role":"Quests & vendor","quests":[{"name":"Bristleback Hides","file":"quests/zones/01-eastbrook-vale/q-boars.md"},{"name":"Stolen Supplies","file":"quests/zones/01-eastbrook-vale/q-supplies.md"}],"market":false,"vendorItems":["Freshly Baked Bread","Refreshing Spring Water","Roasted Boar Meat","Tough Jerky","Minor Healing Potion","Minor Mana Potion"],"render":"npcs/_renders/trader_wilkes.png"},{"id":"brother_aldric_fen","name":"Brother Aldric","title":"Priest of the Vale","zone":"Mirefen Marsh","pos":{"x":-8,"z":296},"greeting":"The Light keep you above the water, you. The dead in this fen do not sleep — they wade.","role":"Quest giver","quests":[{"name":"Aldric's Fallen Star","file":"quests/zones/02-mirefen-marsh/q-aldrics-fallen-star.md"},{"name":"Idols of the Deep","file":"quests/zones/02-mirefen-marsh/q-idols.md"},{"name":"The Drowned Dead","file":"quests/zones/02-mirefen-marsh/q-drowned.md"},{"name":"Censers from the Deep","file":"quests/zones/02-mirefen-marsh/q-drowned-censers.md"},{"name":"No Rest in the Reeds","file":"quests/zones/02-mirefen-marsh/q-no-rest.md"},{"name":"Stopping the Summoning","file":"quests/zones/02-mirefen-marsh/q-summoners.md"},{"name":"The Sunken Bastion","file":"quests/zones/02-mirefen-marsh/q-bastion-door.md"},{"name":"The Mistcaller","file":"quests/zones/02-mirefen-marsh/q-mistcaller.md"},{"name":"The Watch on the Peaks","file":"quests/zones/03-thornpeak-heights/q-highwatch-summons.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/brother_aldric_fen.png"},{"id":"herbalist_yara","name":"Herbalist Yara","title":"Herbalist","zone":"Mirefen Marsh","pos":{"x":10,"z":295},"greeting":"Mind the thicket west of the road. The webs are thick as sailcloth this season.","role":"Quest giver","quests":[{"name":"Silk and Venom","file":"quests/zones/02-mirefen-marsh/q-widows.md"},{"name":"The Broodmother","file":"quests/zones/02-mirefen-marsh/q-broodmother.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/herbalist_yara.png"},{"id":"provisioner_hale","name":"Provisioner Hale","title":"Provisioner","zone":"Mirefen Marsh","pos":{"x":-4,"z":308},"greeting":"Dry boots, dry bread, dry powder — at Fenbridge you get two of the three on a good day.","role":"Quests & vendor","quests":[{"name":"Pelts for the Causeway","file":"quests/zones/02-mirefen-marsh/q-prowler-pelts.md"},{"name":"The Lost Caravan","file":"quests/zones/02-mirefen-marsh/q-fen-supplies.md"},{"name":"The Codfather","file":"quests/zones/02-mirefen-marsh/q-the-codfather.md"},{"name":"The Glutton","file":"quests/zones/02-mirefen-marsh/q-grubjaw.md"}],"market":false,"vendorItems":["Fenbridge Rye Loaf","Marsh Mint Tea","Smoked Mirefen Eel","Silvermist Cordial","Lesser Healing Potion","Lesser Mana Potion","Bogiron Mace","Fenreed Staff","Mirefen Skinner","Bogiron Hauberk","Marshcloth Robe","Reedwoven Jerkin","Fenwalker Boots","Reedwoven Trousers"],"render":"npcs/_renders/provisioner_hale.png"},{"id":"scout_maren","name":"Scout Maren","title":"Marshal's Scout","zone":"Mirefen Marsh","pos":{"x":6,"z":312},"greeting":"Quiet feet and a short blade keep you breathing out here. Speak quick — I am due back in the reeds.","role":"Quest giver","quests":[{"name":"Fetish and Bone","file":"quests/zones/02-mirefen-marsh/q-troll-fetishes.md"},{"name":"Robes in the Reeds","file":"quests/zones/02-mirefen-marsh/q-cult-camp.md"},{"name":"The Knight-Commander's Shame","file":"quests/zones/02-mirefen-marsh/q-olen.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/scout_maren.png"},{"id":"warden_fenwick","name":"Warden Fenwick","title":"Warden of Fenbridge","zone":"Mirefen Marsh","pos":{"x":3,"z":304},"greeting":"Hold at the gate, friend. Past those reeds, the fen does the killing for us.","role":"Quest giver","quests":[{"name":"Muster at Fenbridge","file":"quests/zones/02-mirefen-marsh/q-fenbridge-muster.md"},{"name":"Teeth of the Fen","file":"quests/zones/02-mirefen-marsh/q-prowlers.md"},{"name":"The Deepfen Stirs","file":"quests/zones/02-mirefen-marsh/q-deepfen.md"},{"name":"Back to the Shallows","file":"quests/zones/02-mirefen-marsh/q-deepfen-purge.md"},{"name":"Mounds of the Mirefen","file":"quests/zones/02-mirefen-marsh/q-trolls.md"},{"name":"The Deacon of the Mire","file":"quests/zones/02-mirefen-marsh/q-deacon.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/warden_fenwick.png"},{"id":"tidewatcher_ondrel","name":"Ondrel Vane","title":"Tidewatcher","zone":"The Drowned Temple","pos":{"x":-66,"z":786},"greeting":"The mere drinks the moonlight, friend, and gives back the drowned. I have watched that gate for thirty nights — and tonight it is open.","role":"Quest giver","quests":[{"name":"Light on the Water","file":"quests/zones/04-the-drowned-temple/q-glimmermere-light.md"},{"name":"What the Tarn Gives Up","file":"quests/zones/04-the-drowned-temple/q-tarn-waders.md"},{"name":"The Drowned Choir","file":"quests/zones/04-the-drowned-temple/q-drowned-choir.md"},{"name":"Sethrael the Palecoil","file":"quests/zones/04-the-drowned-temple/q-palecoil.md"},{"name":"Silence the Choir","file":"quests/zones/04-the-drowned-temple/q-silence-the-choir.md"},{"name":"The Drowned Moon","file":"quests/zones/04-the-drowned-temple/q-drowned-moon.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/tidewatcher_ondrel.png"},{"id":"armorer_hode","name":"Armorer Hode","title":"Master Armorer","zone":"Thornpeak Heights","pos":{"x":-2,"z":672},"greeting":"Forge is hot and the grindstone is turning. If it cuts, I sell it.","role":"Vendor","quests":[],"market":false,"vendorItems":["Highwatch Warblade","Craghorn Staff","Icevein Dirk"],"render":"npcs/_renders/armorer_hode.png"},{"id":"brother_aldric_highwatch","name":"Brother Aldric","title":"Priest of the Vale","zone":"Thornpeak Heights","pos":{"x":-10,"z":656},"greeting":"From a chapel yard in the Vale to the roof of the world... the trail we have followed ends here. I can feel the mountain listening.","role":"Quest giver","quests":[{"name":"Chants on the Wind","file":"quests/zones/03-thornpeak-heights/q-zealots.md"},{"name":"Orders from Below","file":"quests/zones/03-thornpeak-heights/q-cult-orders.md"},{"name":"The Phylactery Ring","file":"quests/zones/03-thornpeak-heights/q-necromancers.md"},{"name":"Sigils of the Wyrm","file":"quests/zones/03-thornpeak-heights/q-wyrm-sigils.md"},{"name":"Breaking the Seal","file":"quests/zones/03-thornpeak-heights/q-breaking-the-seal.md"},{"name":"The Voice Below","file":"quests/zones/03-thornpeak-heights/q-voice-below.md"},{"name":"The Sanctum Gate","file":"quests/zones/03-thornpeak-heights/q-sanctum-gate.md"},{"name":"The Grand Necromancer","file":"quests/zones/03-thornpeak-heights/q-velkhar.md"},{"name":"Korzul the Gravewyrm","file":"quests/zones/03-thornpeak-heights/q-gravewyrm.md"},{"name":"Unrest in the Bonefields","file":"quests/zones/03-thornpeak-heights/q-nythraxis-restless-dead.md"},{"name":"Graves of the Forgotten","file":"quests/zones/03-thornpeak-heights/q-nythraxis-graves.md"},{"name":"The Abandoned Crypt","file":"quests/zones/03-thornpeak-heights/q-nythraxis-sealed-crypt.md"},{"name":"The Bound Guardian","file":"quests/zones/03-thornpeak-heights/q-nythraxis-bound-guardian.md"},{"name":"Scourge's End","file":"quests/zones/03-thornpeak-heights/q-nythraxis-scourges-end.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/brother_aldric_highwatch.png"},{"id":"brother_aldric_raid","name":"Brother Aldric","title":"Priest of the Vale","zone":"Thornpeak Heights","pos":{"x":0,"z":0},"greeting":"From a chapel yard in the Vale to the roof of the world... the trail we have followed ends here. I can feel the mountain listening.","role":"Quest giver","quests":[{"name":"Scourge's End","file":"quests/zones/03-thornpeak-heights/q-nythraxis-scourges-end.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/brother_aldric_raid.png"},{"id":"captain_thessaly","name":"Captain Thessaly","title":"Highwatch Captain","zone":"Thornpeak Heights","pos":{"x":4,"z":664},"greeting":"Two hundred years this wall has held, friend. It will not break on my watch — but it groans.","role":"Quest giver","quests":[{"name":"The Watch on the Peaks","file":"quests/zones/03-thornpeak-heights/q-highwatch-summons.md"},{"name":"Stalkers on the Ridge","file":"quests/zones/03-thornpeak-heights/q-stalkers.md"},{"name":"The Captain's Bounty","file":"quests/zones/03-thornpeak-heights/q-ogre-bounty.md"},{"name":"Break the War-Camp","file":"quests/zones/03-thornpeak-heights/q-crushers.md"},{"name":"Warlord Drogmar","file":"quests/zones/03-thornpeak-heights/q-drogmar.md"},{"name":"The Revenant Fields","file":"quests/zones/03-thornpeak-heights/q-revenants.md"},{"name":"Bones of the Vanguard","file":"quests/zones/03-thornpeak-heights/q-revenant-vanguard.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/captain_thessaly.png"},{"id":"loremaster_caddis","name":"Loremaster Caddis","title":"Loremaster","zone":"Thornpeak Heights","pos":{"x":12,"z":655},"greeting":"Mind the loose shale, friend. The mountain has been... restless of late. I intend to learn why.","role":"Quest giver","quests":[{"name":"Deeprock Trouble","file":"quests/zones/03-thornpeak-heights/q-kobold-tunnels.md"},{"name":"The Mountain Wakes","file":"quests/zones/03-thornpeak-heights/q-elementals.md"},{"name":"Cores of the Storm","file":"quests/zones/03-thornpeak-heights/q-shard-cores.md"},{"name":"The Shardlord","file":"quests/zones/03-thornpeak-heights/q-kazzix.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/loremaster_caddis.png"},{"id":"quartermaster_bree","name":"Quartermaster Bree","title":"Highwatch Quartermaster","zone":"Thornpeak Heights","pos":{"x":-5,"z":668},"greeting":"Wool, hardtack, and steel-shod boots — Highwatch runs on all three, and I am short of everything.","role":"Quests & vendor","quests":[{"name":"Winter Is Coming to Highwatch","file":"quests/zones/03-thornpeak-heights/q-stalker-pelts.md"},{"name":"Strange Wax","file":"quests/zones/03-thornpeak-heights/q-glowing-wax.md"}],"market":false,"vendorItems":["Highwatch Trail Hardtack","Meltwater Flask","Roast Mountain Goat","Glacier Melt","Healing Potion","Mana Potion","Highwatch Breastplate","Peakwool Robe","Stalkerhide Jerkin","Cragwalker Boots","Windguard Leggings"],"render":"npcs/_renders/quartermaster_bree.png"},{"id":"scout_maren_highwatch","name":"Scout Maren","title":"Marshal's Scout","zone":"Thornpeak Heights","pos":{"x":7,"z":670},"greeting":"I tracked cultists through the fen at your side, and the trail led here. The peaks are worse, friend. Stay sharp.","role":"Quest giver","quests":[{"name":"Ogres at the Foothills","file":"quests/zones/03-thornpeak-heights/q-ogre-edges.md"},{"name":"Totems of War","file":"quests/zones/03-thornpeak-heights/q-ogre-totems.md"},{"name":"The Bound Guardian","file":"quests/zones/03-thornpeak-heights/q-korgath.md"}],"market":false,"vendorItems":[],"render":"npcs/_renders/scout_maren_highwatch.png"}]}